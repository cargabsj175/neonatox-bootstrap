#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DATA_DIR="$SCRIPT_DIR/bootstrap/data"
PACKS_DIR="$SCRIPT_DIR/bootstrap/packs"
NB_VERSION="v0.1"

LFS="${LFS:-/mnt}"
MODE=""

show_ver() {
	echo "${0} - ${NB_VERSION}"
}

show_help() {
    cat <<'EOF'
Uso: neonatox-bootstrap [opciones] <comando> [opciones-del-comando]

Comandos:
  core            Instalar sistema base (directorios, nhopkg, config, paquetes core)
  kde             Instalar escritorio KDE sobre core existente
  gnome           Instalar escritorio GNOME sobre core existente
  xfce            Instalar escritorio XFCE sobre core existente
  user            Crear usuario del sistema (user --help para opciones)
  grub            Instalar GRUB en dispositivo detectado (grub --help para opciones)
  chroot          Entrar en chroot interactivo en $LFS

Opciones globales:
  -L, --lfs <ruta>      Directorio raíz de destino (default: $LFS env o /mnt)
  --hostname <nombre>   Sobrescribir nombre de host autogenerado
  --device <disp>       Dispositivo para fstab (detección automática)
  --uuid <uuid>         UUID para fstab (detección automática)
  --fstype <tipo>       Tipo de sistema de archivos (detección automática)
  -z, --timezone <zona>     Zona horaria (default: detectada del host)
  -l, --locale <locale>     Locale (default: es_US.UTF-8)
  --no-cleanup              Saltar limpieza post-instalación
  --pack-dir <ruta>         Directorio de archivos de paquetes
  -h, --help                Mostrar esta ayuda
  -v, --version             Muestra la version

Use 'neonatox-bootstrap user --help' o 'neonatox-bootstrap grub --help'
para opciones específicas de cada subcomando.
EOF
    exit 0
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -L|--lfs) LFS="$2"; shift 2 ;;
        --hostname) NHOSTNAME="$2"; shift 2 ;;
        --device) DEVICE_OVERRIDE="$2"; shift 2 ;;
        --uuid) UUID_OVERRIDE="$2"; shift 2 ;;
        --fstype) FSTYPE_OVERRIDE="$2"; shift 2 ;;
        -z|--timezone) TZONE="$2"; shift 2 ;;
        -l|--locale) LOCALE="$2"; shift 2 ;;
        --no-cleanup) SKIP_CLEANUP=1; shift ;;
        --pack-dir) PACKS_DIR="$2"; shift 2 ;;
        -h|--help) show_help ;;
        -v|--version) show_ver ;;
        core|kde|gnome|xfce|chroot|user|grub) MODE="$1"; shift; break ;;
        *) echo "Error: argumento desconocido: $1" >&2; show_help ;;
    esac
done

[[ -z "$MODE" ]] && MODE="core"

# Verificar que LFS no sea la raíz del host
[[ "$LFS" != "/" ]] || {
    echo "Error: LFS apunta a la raíz del sistema host ($LFS). Abortando." >&2
    exit 1
}

# Verificar que LFS exista y sea un punto de montaje (solo en core)
if [[ "$MODE" == "core" ]]; then
    [[ -d "$LFS" ]] || {
        echo "Error: $LFS no existe. Créelo y monte el sistema de archivos destino." >&2
        exit 1
    }
    if command -v mountpoint >/dev/null 2>&1; then
        mountpoint -q "$LFS" || {
            echo "Error: $LFS no es un punto de montaje. Monte el sistema de archivos destino en $LFS." >&2
            exit 1
        }
    else
        awk -v d="$LFS" '$2==d{found=1} END{exit !found}' /proc/mounts || {
            echo "Error: $LFS no es un punto de montaje. Monte el sistema de archivos destino en $LFS." >&2
            exit 1
        }
    fi
fi

# Marcadores de estado
CORE_SENTINEL="${LFS}/var/nhopkg/.core-installed"
DE_SENTINEL="${LFS}/var/nhopkg/.desktop-common-installed"

core_instalado() { [[ -f "$CORE_SENTINEL" ]]; }
de_common_instalado() { [[ -f "$DE_SENTINEL" ]]; }

# Limpieza al salir (error, Ctrl+C, fin normal)
cleanup_all() {
    chroot_cleanup
    rm -rf /tmp/nhopkg /tmp/nhopkg.zip 2>/dev/null || true
}
trap cleanup_all EXIT INT TERM

[[ "${EUID}" == "0" ]] || {
    echo "Error: este script debe ejecutarse como root." >&2
    exit 1
}

##################################################
#  Chroot helpers (mount/unmount VFS)
##################################################
chroot_prepare() {
    mount --bind /dev "${LFS}/dev" 2>/dev/null || true
    mount -t devpts devpts -o gid=5,mode=0620 "${LFS}/dev/pts" 2>/dev/null || true
    mount -t proc proc "${LFS}/proc" 2>/dev/null || true
    mount -t sysfs sysfs "${LFS}/sys" 2>/dev/null || true
    mount -t tmpfs tmpfs "${LFS}/run" 2>/dev/null || true
    if [ -h "${LFS}/dev/shm" ]; then
        install -d -m 1777 "${LFS}$(realpath /dev/shm)" 2>/dev/null || true
    else
        mount -t tmpfs -o nosuid,nodev tmpfs "${LFS}/dev/shm" 2>/dev/null || true
    fi
}

chroot_cleanup() {
    umount -l "${LFS}/dev/shm" 2>/dev/null || true
    umount -l "${LFS}/dev/pts" 2>/dev/null || true
    umount -l "${LFS}/run"     2>/dev/null || true
    umount -l "${LFS}/sys"     2>/dev/null || true
    umount -l "${LFS}/dev"     2>/dev/null || true
    umount -l "${LFS}/proc"    2>/dev/null || true
}

chroot_run() {
    chroot "$LFS" /bin/bash -c "$*"
}

##################################################
#  Custom triggers — $LFS/var/nhopkg/triggers/*.sh
##################################################
run_triggers() {
    local TDIR="${LFS}/var/nhopkg/triggers"
    local LOG="${PWD}/neonatox-triggers.log"

    [[ -d "$TDIR" ]] || return 0

    echo "=== [triggers] Ejecutando disparadores para ${section} ===" | tee -a "$LOG"

    for t in "$TDIR"/*.sh; do
        [[ -f "$t" ]] || continue
        local name
        name="$(basename "$t")"
        echo "  -> ${name}" | tee -a "$LOG"
        if chroot_run "bash /var/nhopkg/triggers/${name}" >> "$LOG" 2>&1; then
            echo "  [ok] ${name}" | tee -a "$LOG"
        else
            echo "  [fallo] ${name} (codigo $?) — continuando" | tee -a "$LOG"
        fi
    done

    echo "=== [triggers] - [${section}] Completo ===" | tee -a "$LOG"
    rm -f "$TDIR"/*.sh
    rmdir "$TDIR" 2>/dev/null || true
}

##################################################
#  Install base system — 01-base-neonatox.sh
##################################################
install_core() {
	section="Core"
    if core_instalado; then
        echo "core ya instalado en $LFS. Saltando." >&2
        return 0
    fi
    echo "=== [core] Creando jerarquía de directorios ==="

    mkdir -pv ${LFS}/usr/{bin,lib,lib32}
    ln -sfv usr/bin   ${LFS}/bin
    ln -sfv usr/bin   ${LFS}/sbin
    ln -sfv usr/lib   ${LFS}/lib
    ln -sfv usr/lib   ${LFS}/lib64
    ln -sfv usr/lib32 ${LFS}/lib32
    ln -sfv bin       ${LFS}/usr/sbin
    mkdir -pv ${LFS}/{dev,proc,sys,run}
    mkdir -pv ${LFS}/{boot,home,mnt,opt,srv}
    mkdir -pv ${LFS}/etc/{opt,sysconfig,skel,profile.d}
    mkdir -pv ${LFS}/etc/polkit-1/rules.d
    mkdir -pv ${LFS}/lib/firmware
    mkdir -pv ${LFS}/media/{floppy,cdrom}
    mkdir -pv ${LFS}/usr/{,local/}{include,src}
    mkdir -pv ${LFS}/usr/lib/locale
    mkdir -pv ${LFS}/usr/local/{bin,lib,sbin}
    mkdir -pv ${LFS}/usr/{,local/}share/{color,dict,doc,info,locale,man}
    mkdir -pv ${LFS}/usr/{,local/}share/{misc,terminfo,zoneinfo}
    mkdir -pv ${LFS}/usr/{,local/}share/man/man{1..8}
    mkdir -pv ${LFS}/var/{cache,local,log,mail,opt,spool}
    mkdir -pv ${LFS}/var/lib/{color,misc,locate}
    ln -sfv /run ${LFS}/var/run
    ln -sfv /run/lock ${LFS}/var/lock
    install -dv -m 0750 ${LFS}/root
    install -dv -m 1777 ${LFS}/tmp ${LFS}/var/tmp

    echo "=== [core] Copiando archivos de configuración estáticos ==="
    cp -av "$DATA_DIR/etc/." "$LFS/etc/"
    cp -av "$DATA_DIR/etc/skel/." "$LFS/root/"

    if [[ -n "${LOCALE:-}" ]]; then
        cat > "${LFS}/etc/locale.conf" <<EOF
# Generated by neonatox-bootstrap

export LANG=$LOCALE

EOF
    fi

    echo "=== [core] Enlaces simbólicos del sistema ==="
    ln -sf gawk "${LFS}/usr/bin/awk"
    ln -sf bash "${LFS}/usr/bin/sh"
    ln -sf /proc/self/mounts "${LFS}/etc/mtab"

    echo "=== [core] Creando directorios para metadata de nhopkg ==="
    mkdir -p ${LFS}/var/nhopkg/{cache,files,logs,packages,repo}

    echo "=== [core] Generando archivos dinámicos ==="

    # fstab — detecta dispositivo/UUID/FSTYPE
    DEV=""
    if command -v findmnt >/dev/null 2>&1; then
        DEV="$(findmnt -no SOURCE --target "$LFS" 2>/dev/null | sed 's/\[.*\]//' | tr -d '[:space:]')"
        VOLUME="$(findmnt -no OPTIONS --target "$LFS" 2>/dev/null | sed -n 's/.*subvol=\([^,]*\).*/\1/p' || true)"
    fi
    if [[ -z "$DEV" ]] || [[ ! -b "$DEV" ]]; then
        DEV="$(df -P "$LFS" | awk 'NR==2{print $1}' | sed 's/\[.*\]//')"
    fi
    if [[ ! -b "$DEV" ]]; then
        echo "Error: No se pudo detectar dispositivo válido para $LFS" >&2
        exit 1
    fi
    echo "Dispositivo detectado: $DEV"
    if command -v blkid >/dev/null 2>&1; then
        BLKID_OUT="$(blkid "$DEV" 2>/dev/null || true)"
    elif command -v sudo >/dev/null 2>&1; then
        BLKID_OUT="$(sudo blkid "$DEV" 2>/dev/null || true)"
    else
        BLKID_OUT=""
    fi
    UUID="${UUID_OVERRIDE:-$(echo "$BLKID_OUT" | sed -n 's/.*UUID="\([^"]*\)".*/\1/p')}"
    FSTYPE="${FSTYPE_OVERRIDE:-$(echo "$BLKID_OUT" | sed -n 's/.*TYPE="\([^"]*\)".*/\1/p')}"
    if [[ -z "$UUID" ]]; then
        echo "Error: No se pudo obtener UUID de $DEV" >&2
        exit 1
    fi
    echo "UUID: $UUID | Tipo: $FSTYPE"
    if [[ "$FSTYPE" == "btrfs" ]]; then
        MOUNT_OPTS="compress=zstd:3,noatime,subvol=$VOLUME"
        FS_PASS="0 0"
    else
        MOUNT_OPTS="defaults"
        FS_PASS="0 1"
    fi
    cat > "${LFS}/etc/fstab" <<EOF
# Generated by neonatox-bootstrap

UUID=$UUID  /  $FSTYPE  $MOUNT_OPTS  $FS_PASS
EOF
    echo "    [INFO] fstab generado"

    # hosts / hostname — usa DMI + random
    if [[ -z "${NHOSTNAME:-}" ]]; then
        vendor=$(cat /sys/devices/virtual/dmi/id/board_vendor 2>/dev/null | tr '[:upper:]' '[:lower:]' | tr -c 'a-z0-9' '-' | sed 's/^-\+//;s/-\+$//' | cut -c1-6)
        model=$(cat /sys/devices/virtual/dmi/id/board_name 2>/dev/null | tr '[:upper:]' '[:lower:]' | tr -c 'a-z0-9' '-' | sed 's/^-\+//;s/-\+$//' | cut -c1-6)
        ramdomnum=$(head /dev/urandom | tr -dc 'a-f0-9' | head -c 4)
        NHOSTNAME="${vendor}-${model}-${ramdomnum}"
    fi
    cat > "${LFS}/etc/hosts" <<EOF
127.0.0.1  localhost ${NHOSTNAME}
::1        localhost

EOF

	echo "    [INFO] hosts generado"

    cat > "${LFS}/etc/hostname" <<EOF
# Begin /etc/hostname
${NHOSTNAME}

# End /etc/hostname
EOF

	echo "    [INFO] hostname generado"

    # timezone
    if [[ -z "${TZONE:-}" ]] && command -v readlink >/dev/null 2>&1; then
        TZONE="$(readlink /etc/localtime 2>/dev/null | sed -n 's|.*/zoneinfo/||p')"
    fi
    TZONE="${TZONE:-America/Caracas}"
    ln -sf "/usr/share/zoneinfo/${TZONE}" "${LFS}/etc/localtime"
    echo "${TZONE}" > "${LFS}/etc/timezone"
    
    echo "    [INFO] timezone generado"

    # machine-id
    if command -v openssl >/dev/null 2>&1; then
        openssl rand -hex 16 > "${LFS}/etc/machine-id"
    elif [[ -r /proc/sys/kernel/random/boot_id ]]; then
        tr -d '-' < /proc/sys/kernel/random/boot_id > "${LFS}/etc/machine-id"
    elif [[ -r /proc/sys/kernel/random/uuid ]]; then
        tr -d '-' < /proc/sys/kernel/random/uuid > "${LFS}/etc/machine-id"
    else
        echo "deadbeefdeadbeefdeadbeefdeadbeef" > "${LFS}/etc/machine-id"
    fi
    
    echo "    [INFO] machine-id generado"
    

    echo "=== [core] Poblando BD de paquetes e instalando core ==="
    nhopkg --root "$LFS" -U
    nhopkg --root "$LFS" -RS $(awk 'NF && !/^#/' "$PACKS_DIR/core") $(awk 'NF && !/^#/' "$PACKS_DIR/base-extra")
    nhopkg --root "$LFS" -RS grub --no-check-deps
    nhopkg --root "$LFS" -RS libpwquality 
    # harcoded uninstall for pam (meanwhile)
    rm -f "$LFS"/var/nhopkg/*/pam-*
    nhopkg --root "$LFS" -RS pam
    nhopkg --root "$LFS" -RS nhopkg 
    chroot_prepare
    run_triggers
    chroot_cleanup
    touch "$CORE_SENTINEL"
    echo "=== [core] Listo ==="
}

##################################################
#  Desktop-common setup (shared by all DEs)
##################################################
install_desktop_common() {
	section="Desktop Common"
    # Verificar si esta instalada la seccion
    de_common_instalado && return 0
    
    #Instalar paquetes de la seccion
    nhopkg --root "$LFS" -RS $(awk 'NF && !/^#/' "$PACKS_DIR/desktop-common")
    
    chroot_prepare
    chroot_run "systemctl enable lightdm"
    run_triggers
    chroot_cleanup
    
    touch "$DE_SENTINEL"
}

##################################################
#  Desktop post-install cleanup
##################################################
cleanup() {
    if [[ -z "${SKIP_CLEANUP:-}" ]]; then
        chroot_run "rm -rf /usr/src/* /var/nhopkg/cache/* /tmp/* /tmp/.* 2>/dev/null; exit 0"
    fi
}

##################################################
#  KDE
##################################################
install_kde() {
    # Asegurar dependencias (core + desktop-common se saltan si ya instalados)
    core_instalado || install_core
    install_desktop_common
    
    section="KDE"
    
    #Instalar paquetes de la seccion
    nhopkg --root "$LFS" -RS $(awk 'NF && !/^#/' "$PACKS_DIR/kde") $(awk 'NF && !/^#/' "$PACKS_DIR/kde-extra")
    
    # Disparadores en contexto chroot + limpieza
    chroot_prepare
    run_triggers
    cleanup
    chroot_cleanup
}

##################################################
#  GNOME
##################################################

install_gnome() {
	# Asegurar dependencias (core + desktop-common se saltan si ya instalados)
    core_instalado || install_core
    install_desktop_common
    
    section="Gnome"
    
    #Instalar paquetes de la seccion
    nhopkg --root "$LFS" -RS $(awk 'NF && !/^#/' "$PACKS_DIR/gnome") $(awk 'NF && !/^#/' "$PACKS_DIR/gnome-extra")
    nhopkg --root "$LFS" -Rr qt5 qt6 > /dev/null 2>&1
    
    # Disparadores en contexto chroot + limpieza
    chroot_prepare
    run_triggers
    cleanup
    chroot_cleanup
}

##################################################
#  XFCE
##################################################

install_xfce() {
    # Asegurar dependencias (core + desktop-common se saltan si ya instalados)
    core_instalado || install_core
    install_desktop_common
    
    section="Xfce"
    
    #Instalar paquetes de la seccion
    nhopkg --root "$LFS" -RS $(awk 'NF && !/^#/' "$PACKS_DIR/xfce") $(awk 'NF && !/^#/' "$PACKS_DIR/xfce-extra")
    nhopkg --root "$LFS" -Rr qt6 > /dev/null 2>&1
    
    # Disparadores en contexto chroot + limpieza
    chroot_prepare
    run_triggers
    cleanup
    chroot_cleanup
}

##################################################
#  Chroot interactivo
##################################################

do_chroot() {
    core_instalado || { echo "Error: ejecute 'core' primero." >&2; exit 1; }
    chroot_prepare
    echo "Entrando en chroot $LFS (escriba 'exit' para salir)"
    chroot "$LFS" /bin/bash
    chroot_cleanup
}

##################################################
#  User creation
##################################################
cmd_user() {
    local USERNAME="" FULLNAME="" GROUPS="users" SHELL="/bin/bash" PASSWORD=""
    local NO_CREATE_HOME="" UID_SPEC="" GID_SPEC=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -u|--username) USERNAME="$2"; shift 2 ;;
            -f|--fullname) FULLNAME="$2"; shift 2 ;;
            -g|--groups) GROUPS="$2"; shift 2 ;;
            -s|--shell) SHELL="$2"; shift 2 ;;
            -p|--password) PASSWORD="$2"; shift 2 ;;
            --no-create-home) NO_CREATE_HOME=1; shift ;;
            --uid) UID_SPEC="$2"; shift 2 ;;
            --gid) GID_SPEC="$2"; shift 2 ;;
            -h|--help)
                cat <<'EOF'
Uso: neonatox-bootstrap [opciones] user [opciones]

Opciones:
  -u, --username <name>  Nombre de usuario (requerido)
  -f, --fullname <texto> Nombre completo (GECOS)
  -g, --groups <lista>   Grupos adicionales separados por coma (default: users)
  -s, --shell <ruta>     Shell de login (default: /bin/bash)
  -p, --password <pass>  Contraseña (vía chpasswd)
  --no-create-home       No crear /home/<username>
  --uid <num>            UID específico
  --gid <num>            GID del grupo primario
  -h, --help             Mostrar esta ayuda
EOF
                exit 0 ;;
            *) echo "Error: opción desconocida: $1" >&2; exit 1 ;;
        esac
    done

    [[ -n "$USERNAME" ]] || { echo "Error: --username es requerido" >&2; exit 1; }

    core_instalado || { echo "Error: ejecute 'core' primero." >&2; exit 1; }

    chroot_prepare

    if [[ "$USERNAME" == "root" ]]; then
        if [[ -n "$PASSWORD" ]]; then
            echo "root:$PASSWORD" | chroot "$LFS" chpasswd
            echo "  [ok] contraseña de root actualizada"
        else
            echo "  [saltado] no se proveyó contraseña para root"
        fi
    else
        # Validar grupos
        local GROUP_LIST=() VALID_GROUPS=() g
        IFS=',' read -ra GROUP_LIST <<< "$GROUPS"
        for g in "${GROUP_LIST[@]}"; do
            if grep -q "^${g}:" "$LFS/etc/group" 2>/dev/null; then
                VALID_GROUPS+=("$g")
            else
                echo "  [aviso] grupo '$g' no existe — ignorado"
            fi
        done

        # Construir comando useradd
        local UA="useradd"
        [[ -z "$NO_CREATE_HOME" ]] && UA+=" -m" || UA+=" -M"
        [[ -n "$UID_SPEC" ]] && UA+=" -u $UID_SPEC"
        [[ -n "$GID_SPEC" ]] && UA+=" -g $GID_SPEC"
        [[ -n "$FULLNAME" ]] && UA+=" -c \"$FULLNAME\""
        [[ -n "$SHELL" ]] && UA+=" -s $SHELL"
        if [[ ${#VALID_GROUPS[@]} -gt 0 ]]; then
            local GSTR
            GSTR=$(IFS=,; echo "${VALID_GROUPS[*]}")
            UA+=" -G $GSTR"
        fi
        UA+=" $USERNAME"

        chroot_run "$UA" || echo "  [aviso] useradd falló (puede que el usuario ya exista)"

        if [[ -n "$PASSWORD" ]]; then
            echo "$USERNAME:$PASSWORD" | chroot "$LFS" chpasswd
            echo "  [ok] contraseña establecida para $USERNAME"
        fi
    fi

    run_triggers
    chroot_cleanup
}

##################################################
#  GRUB installation
##################################################
cmd_grub() {
    local DEVICE="" EFI="" EFI_DIR="/boot" REINSTALL=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -d|--device) DEVICE="$2"; shift 2 ;;
            --efi) EFI=1; shift ;;
            --efi-dir) EFI_DIR="$2"; shift 2 ;;
            --reinstall) REINSTALL="--reinstall"; shift ;;
            -h|--help)
                cat <<'EOF'
Uso: neonatox-bootstrap [opciones] grub [opciones]

Opciones:
  -d, --device <disp>  Dispositivo donde instalar GRUB (default: auto desde fstab)
  --efi                Modo UEFI (x86_64-efi), legacy por defecto
  --efi-dir <dir>      Directorio de la partición EFI (default: /boot)
  --reinstall          Pasar --reinstall a grub-install
  -h, --help           Mostrar esta ayuda
EOF
                exit 0 ;;
            *) echo "Error: opción desconocida: $1" >&2; exit 1 ;;
        esac
    done

    core_instalado || { echo "Error: ejecute 'core' primero." >&2; exit 1; }

    # Detectar dispositivo desde fstab si no se proveyó
    if [[ -z "$DEVICE" ]]; then
        local FSTAB_DEV PART
        FSTAB_DEV=$(awk '$2=="/"{print $1}' "$LFS/etc/fstab" 2>/dev/null)
        [[ -n "$FSTAB_DEV" ]] || { echo "Error: no se pudo detectar dispositivo desde /etc/fstab" >&2; exit 1; }

        if [[ "$FSTAB_DEV" =~ ^UUID= ]]; then
            local UUID="${FSTAB_DEV#UUID=}"
            local BY_UUID="/dev/disk/by-uuid/$UUID"
            if [[ -e "$BY_UUID" ]]; then
                PART=$(readlink -f "$BY_UUID")
            else
                echo "Error: no se pudo resolver UUID=$UUID" >&2; exit 1
            fi
        else
            PART="$FSTAB_DEV"
        fi
        # /dev/sda3 -> /dev/sda , /dev/nvme0n1p2 -> /dev/nvme0n1
        DEVICE=$(echo "$PART" | sed 's/[0-9]*$//; s/p$//')
    fi

    [[ -b "$DEVICE" ]] || { echo "Error: $DEVICE no es un dispositivo de bloque" >&2; exit 1; }
    echo "  [ok] dispositivo: $DEVICE"

    chroot_prepare

    if [[ -n "$EFI" ]]; then
        chroot_run "grub-install --target=x86_64-efi --efi-directory=$EFI_DIR --bootloader-id=NeonatoX $REINSTALL"
    else
        chroot_run "grub-install $REINSTALL $DEVICE"
    fi

    chroot_run "grub-mkconfig -o /boot/grub/grub.cfg"

    run_triggers
    chroot_cleanup
}

##################################################
#  Main
##################################################
case "$MODE" in
    core)   install_core ;;
    kde)    install_kde ;;
    gnome)  install_gnome ;;
    xfce)   install_xfce ;;
    user)   cmd_user "$@" ;;
    grub)   cmd_grub "$@" ;;
    chroot) do_chroot ;;
esac
